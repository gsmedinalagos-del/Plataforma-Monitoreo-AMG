let fn_prd_mlp_ada_dom_global_status = (startTime:datetime, endTime:datetime) {
  let metric_status = union
      (fn_prd_mlp_ada_dom_dispatch_status(startTime,endTime)
      | project Metric='Dispatch', Status=iff(color == "#E53935", "NOOK", "OK")),
      (fn_prd_mlp_ada_dom_drillit_status(startTime,endTime)
      | project Metric='Drillit', Status=iff(color == "#E53935", "NOOK", "OK")),
      (fn_prd_mlp_ada_dom_blockgrade_status(startTime,endTime)
      | project Metric='Blockgrade', Status=iff(color == "#E53935", "NOOK", "OK")),
      (fn_prd_mlp_ada_dom_pi_status(startTime,endTime)
      | project Metric='PI', Status=iff(color == "#E53935", "NOOK", "OK")),
      (fn_prd_mlp_ada_dom_plans_status(startTime,endTime)
      | project Metric='Plans', Status=iff(color == "#E53935", "NOOK", "OK")),
      (fn_prd_mlp_ada_dom_meteodata_status(startTime,endTime)
      | project Metric='Meteodata', Status=iff(color == "#E53935", "NOOK", "OK")),
      (fn_prd_mlp_ada_dom_kpi_status(startTime,endTime)
      | project Metric='KPI', Status=iff(color == "#E53935", "NOOK", "OK")),
      (fn_prd_mlp_ada_dom_alarm_status(startTime,endTime)
      | project Metric='Alarmas', Status=iff(color == "#E53935", "NOOK", "OK")),
      (fn_prd_mlp_ada_dom_front_status(startTime,endTime)
      | project Metric='Front', Status=iff(color == "#E53935", "NOOK", "OK")),
      (fn_prd_mlp_ada_dom_optimizador_status(startTime,endTime)
      | project Metric='Optimizador Mezcla', Status=iff(color == "#E53935", "NOOK", "OK")),
      (fn_prd_mlp_ada_dom_settings_status(startTime,endTime)
      | project Metric='Settings', Status=iff(color == "#E53935", "NOOK", "OK"))
    | summarize Status = take_any(Status) by Metric
    | evaluate pivot(Metric, take_any(Status));
  metric_status
  | project
      Dispatch = iff(column_ifexists('Dispatch', 'OK') == 'NOOK', 'ALERT', 'OK'),
      Drillit = iff(column_ifexists('Drillit', 'OK') == 'NOOK', 'ALERT', 'OK'),
      Blockgrade = iff(column_ifexists('Blockgrade', 'OK') == 'NOOK', 'ALERT', 'OK'),
      PI = iff(column_ifexists('PI', 'OK') == 'NOOK', 'ALERT', 'OK'),
      Plans = iff(column_ifexists('Plans', 'OK') == 'NOOK', 'ALERT', 'OK'),
      Meteodata = iff(column_ifexists('Meteodata', 'OK') == 'NOOK', 'ALERT', 'OK'),
      KPI = iff(column_ifexists('KPI', 'OK') == 'NOOK', 'ALERT', 'OK'),
      Alarmas = iff(column_ifexists('Alarmas', 'OK') == 'NOOK', 'ALERT', 'OK'),
      Front = iff(column_ifexists('Front', 'OK') == 'NOOK', 'ALERT', 'OK'),
      ['Optimizador Mezcla'] = iff(column_ifexists('Optimizador Mezcla', 'OK') == 'NOOK', 'ALERT', 'OK'),
      Settings = iff(column_ifexists('Settings', 'OK') == 'NOOK', 'ALERT', 'OK')
  | extend color = iff(
      Dispatch == 'ALERT' or Drillit == 'ALERT' or Blockgrade == 'ALERT' or PI == 'ALERT' or
      Plans == 'ALERT' or Meteodata == 'ALERT' or KPI == 'ALERT' or Alarmas == 'ALERT' or Front == 'ALERT' or
      ['Optimizador Mezcla'] == 'ALERT' or Settings == 'ALERT',
      '#E53935',
      '#EAF4EA'
    )
};

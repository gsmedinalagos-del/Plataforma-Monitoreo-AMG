let fn_prd_ssag_eval_desactualizacion = (job_name:string, endTime:datetime, ventana:timespan, log_prefix:string, ts_offset:int, ts_length:int, max_minutos:int) {
    fn_src_ssag_consolelogs_all(endTime - ventana, endTime)
    | where ContainerJobName_s == job_name
    | where Log_s startswith log_prefix
    | summarize LastLogTimeGenerated = arg_max(TimeGenerated, Log_s)
    | extend ultimo_timestamp = todatetime(substring(Log_s, ts_offset, ts_length))
    | extend diff_min = datetime_diff('minute', LastLogTimeGenerated, ultimo_timestamp)
    | project Status = iff(isnull(LastLogTimeGenerated) or isnull(ultimo_timestamp) or diff_min > max_minutos, 'NOOK', 'OK')
};
